---
const aboutContent = [
  {
    id: 1,
    title: 'Our Mission',
    text: "At One Space Away, we believe that great design isn't just about aesthetics — it's about creating spaces that feel like home. That's why we take the time to understand your vision, lifestyle, and needs, ensuring every detail is tailored to you.",
  },
  {
    id: 2,
    title: 'Our Vision',
    text: 'With this deep understanding, we transform ideas into thoughtfully designed interiors. From carefully selected materials to customized layouts, we focus on every detail to make your home uniquely yours.',
  },
];
---

<section id="about" class="about">
  <div class="section-container">
    <span class="section-tag">OUR STORY</span>
    <h2 class="section-title">Every home has a story.</h2>
    <div class="about-container">
      <div class="about-image-wrapper">
        <img
          src="/src/assets/images/two-women-sitting.png"
          alt="Our company story visual"
          class="media"
        />
      </div>
      <div class="about-content">
        {
          aboutContent.map(content => (
            <>
              <h3 class="about-subtitle">{content.title}</h3>
              <p class="about-text">{content.text}</p>
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .about-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--px-64);
    align-items: center;
  }

  .about-image-wrapper {
    width: 100%;
    height: 100%;
    min-height: 28.125rem;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .about-content {
    max-width: 37.5rem;
  }

  .about-subtitle {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--px-16);
  }

  .about-text {
    margin-bottom: var(--px-32);
  }

  .about-text:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 64rem) {
    .about-container {
      gap: var(--px-32);
    }

    .about-image-wrapper {
      min-height: 25rem;
    }

    .about-content {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 48rem) {
    .about-container {
      grid-template-columns: 1fr;
      gap: var(--px-32);
    }

    .about-image-wrapper {
      min-height: 21.875rem;
      order: -1;
    }
  }
</style>
